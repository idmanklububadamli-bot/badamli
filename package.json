{
  "name": "arenasmart",
  "version": "1.0.0",
  "description": "ArenaSmart - Sports Tournament Management System",
  "private": true,
  "type": "module",
  "scripts": {
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "server": "npm start --prefix backend",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "@supabase/supabase-js": "^2.108.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0"
  }
}
